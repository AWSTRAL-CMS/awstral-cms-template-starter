---
interface Props {
  id: string;
  logo?: string;
  siteName?: string;
  links?: Array<{
    label: string;
    href: string;
  }>;
  ctaText?: string;
  ctaHref?: string;
  styleOverrides?: {
    backgroundColor?: string;
    textColor?: string;
    padding?: string;
  };
}

const {
  id,
  logo = "",
  siteName = "Site Name",
  links = [],
  ctaText = "",
  ctaHref = "#",
  styleOverrides = {},
  ...cmsAttributes
} = Astro.props;

const inlineStyles = {
  "--block-bg-color": styleOverrides.backgroundColor || "transparent",
  "--block-text-color": styleOverrides.textColor || "inherit",
  "--block-padding": styleOverrides.padding || "1rem 2rem",
} as const;
---

<header
  class="navbar-block"
  data-cms-id={id}
  {...cmsAttributes}
  style={`${Object.entries(inlineStyles)
    .map(([k, v]) => `${k}: ${v}`)
    .join("; ")}`}
>
  <div class="navbar-container">
    <a href="/" class="navbar-brand">
      {
        logo ? (
          <img src={logo} alt={siteName} class="navbar-logo" />
        ) : (
          <span class="navbar-site-name">{siteName}</span>
        )
      }
    </a>

    <nav class="navbar-nav">
      {
        links.map((link) => (
          <a href={link.href} class="nav-link">
            {link.label}
          </a>
        ))
      }
    </nav>

    {
      ctaText && (
        <a href={ctaHref} class="navbar-cta">
          {ctaText}
        </a>
      )
    }
  </div>
</header>

<style>
  .navbar-block {
    background-color: var(--block-bg-color);
    color: var(--block-text-color);
    padding: var(--block-padding);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .navbar-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .navbar-brand {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: var(--block-text-color);
  }

  .navbar-logo {
    height: 40px;
    width: auto;
  }

  .navbar-site-name {
    font-size: 1.25rem;
    font-weight: 700;
  }

  .navbar-nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex: 1;
    justify-content: center;
  }

  .nav-link {
    color: var(--block-text-color);
    text-decoration: none;
    font-weight: 500;
    opacity: 0.8;
    transition: opacity 0.2s ease;
  }

  .nav-link:hover {
    opacity: 1;
  }

  .navbar-cta {
    padding: 0.5rem 1rem;
    border-radius: var(--theme-border-radius);
    background: var(--theme-color-primary);
    color: white;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.875rem;
    transition: opacity 0.2s ease;
  }

  .navbar-cta:hover {
    opacity: 0.9;
  }

  @media (max-width: 768px) {
    .navbar-nav {
      display: none;
    }
  }
</style>
