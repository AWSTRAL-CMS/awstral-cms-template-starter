---
interface Props {
  id: string;
  title?: string;
  testimonials: Array<{
    quote: string;
    author: string;
    role?: string;
    avatar?: string;
  }>;
  styleOverrides?: {
    backgroundColor?: string;
    textColor?: string;
    padding?: string;
  };
}

const {
  id,
  title = "What Our Customers Say",
  testimonials = [],
  styleOverrides = {},
  ...cmsAttributes
} = Astro.props;

const inlineStyles = {
  "--block-bg-color": styleOverrides.backgroundColor || "transparent",
  "--block-text-color": styleOverrides.textColor || "inherit",
  "--block-padding": styleOverrides.padding || "4rem 2rem",
} as const;
---

<section
  class="testimonials-block"
  data-cms-id={id}
  {...cmsAttributes}
  style={`${Object.entries(inlineStyles)
    .map(([k, v]) => `${k}: ${v}`)
    .join("; ")}`}
>
  <div class="testimonials-container">
    {title && <h2 class="testimonials-title">{title}</h2>}
    <div class="testimonials-grid">
      {
        testimonials.map((testimonial) => (
          <div class="testimonial-card">
            <blockquote class="testimonial-quote">"{testimonial.quote}"</blockquote>
            <div class="testimonial-author">
              {testimonial.avatar && (
                <img src={testimonial.avatar} alt={testimonial.author} class="author-avatar" />
              )}
              <div class="author-info">
                <div class="author-name">{testimonial.author}</div>
                {testimonial.role && <div class="author-role">{testimonial.role}</div>}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .testimonials-block {
    background-color: var(--block-bg-color);
    color: var(--block-text-color);
    padding: var(--block-padding);
  }

  .testimonials-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .testimonials-title {
    text-align: center;
    font-size: 2.25rem;
    font-weight: 700;
    margin: 0 0 3rem;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .testimonial-card {
    padding: 2rem;
    border-radius: var(--theme-border-radius);
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .testimonial-quote {
    font-size: 1.125rem;
    line-height: 1.7;
    margin: 0;
    font-style: italic;
    opacity: 0.85;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .author-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
  }

  .author-name {
    font-weight: 600;
    font-size: 1rem;
  }

  .author-role {
    font-size: 0.875rem;
    opacity: 0.7;
  }
</style>
