---
interface Props {
  id: string;
  companyName?: string;
  links?: Array<{
    label: string;
    href: string;
  }>;
  socialLinks?: Array<{
    label: string;
    href: string;
    icon?: string;
  }>;
  copyright?: string;
  styleOverrides?: {
    backgroundColor?: string;
    textColor?: string;
    padding?: string;
  };
}

const {
  id,
  companyName = "Company",
  links = [],
  socialLinks = [],
  copyright = "",
  styleOverrides = {},
  ...cmsAttributes
} = Astro.props;

const currentYear = new Date().getFullYear();
const defaultCopyright = `© ${currentYear} ${companyName}. All rights reserved.`;

const inlineStyles = {
  "--block-bg-color": styleOverrides.backgroundColor || "#1e293b",
  "--block-text-color": styleOverrides.textColor || "#ffffff",
  "--block-padding": styleOverrides.padding || "3rem 2rem",
} as const;
---

<footer
  class="footer-block"
  data-cms-id={id}
  {...cmsAttributes}
  style={`${Object.entries(inlineStyles)
    .map(([k, v]) => `${k}: ${v}`)
    .join("; ")}`}
>
  <div class="footer-container">
    <div class="footer-brand">
      <h3 class="company-name">{companyName}</h3>
    </div>

    {
      links.length > 0 && (
        <nav class="footer-links">
          {links.map((link) => (
            <a href={link.href} class="footer-link">
              {link.label}
            </a>
          ))}
        </nav>
      )
    }

    {
      socialLinks.length > 0 && (
        <div class="footer-social">
          {socialLinks.map((link) => (
            <a href={link.href} class="social-link" aria-label={link.label}>
              {link.icon || link.label}
            </a>
          ))}
        </div>
      )
    }

    <div class="footer-copyright">
      {copyright || defaultCopyright}
    </div>
  </div>
</footer>

<style>
  .footer-block {
    background-color: var(--block-bg-color);
    color: var(--block-text-color);
    padding: var(--block-padding);
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
    text-align: center;
  }

  .company-name {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    justify-content: center;
  }

  .footer-link {
    color: var(--block-text-color);
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.2s ease;
  }

  .footer-link:hover {
    opacity: 1;
  }

  .footer-social {
    display: flex;
    gap: 1rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    color: var(--block-text-color);
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .social-link:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .footer-copyright {
    font-size: 0.875rem;
    opacity: 0.6;
  }
</style>
