---
interface Props {
  id: string;
  title?: string;
  features: Array<{
    icon?: string;
    title: string;
    description: string;
  }>;
  columns?: number;
  styleOverrides?: {
    backgroundColor?: string;
    textColor?: string;
    padding?: string;
  };
}

const {
  id,
  title = "Features",
  features = [],
  columns = 3,
  styleOverrides = {},
  ...cmsAttributes
} = Astro.props;

const inlineStyles = {
  "--block-bg-color": styleOverrides.backgroundColor || "transparent",
  "--block-text-color": styleOverrides.textColor || "inherit",
  "--block-padding": styleOverrides.padding || "4rem 2rem",
  "--grid-columns": columns,
} as const;
---

<section
  class="features-block"
  data-cms-id={id}
  {...cmsAttributes}
  style={`${Object.entries(inlineStyles)
    .map(([k, v]) => `${k}: ${v}`)
    .join("; ")}`}
>
  <div class="features-container">
    {title && <h2 class="features-title">{title}</h2>}
    <div class="features-grid">
      {
        features.map((feature) => (
          <div class="feature-card">
            {feature.icon && <div class="feature-icon">{feature.icon}</div>}
            <h3 class="feature-title">{feature.title}</h3>
            <p class="feature-description">{feature.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .features-block {
    background-color: var(--block-bg-color);
    color: var(--block-text-color);
    padding: var(--block-padding);
  }

  .features-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .features-title {
    text-align: center;
    font-size: 2.25rem;
    font-weight: 700;
    margin: 0 0 3rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(var(--grid-columns), 1fr);
    gap: 2rem;
  }

  @media (max-width: 768px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }

  .feature-card {
    padding: 1.5rem;
    border-radius: var(--theme-border-radius);
    background: rgba(0, 0, 0, 0.02);
    transition: transform 0.2s ease;
  }

  .feature-card:hover {
    transform: translateY(-4px);
  }

  .feature-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .feature-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }

  .feature-description {
    font-size: 1rem;
    opacity: 0.8;
    margin: 0;
    line-height: 1.6;
  }
</style>
