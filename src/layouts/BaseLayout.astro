---
import "../styles/global.css";
import { themeInlineCssVariables } from "../lib/theme";

interface Props {
  title?: string;
}

const { title = "Awstral Starter Template" } = Astro.props;
---

<html lang="en" style={themeInlineCssVariables}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
